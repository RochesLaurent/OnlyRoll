# ==========================================
# Configuration de test par défaut
# Ce fichier est utilisé par la CI/CD
# ==========================================

# Symfony Configuration
KERNEL_CLASS='App\Kernel'
APP_ENV=test
APP_DEBUG=false
APP_SECRET='$ecretf0rt3st'

# Deprecations
SYMFONY_DEPRECATIONS_HELPER=999999

# Panther (tests E2E)
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots

# Database (sera surchargé par la CI)
DATABASE_URL="mysql://root:root@127.0.0.1:3306/onlyroll_test?serverVersion=9.0"

# Redis
REDIS_URL="redis://127.0.0.1:6379"

# CORS
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# JWT Keys (seront générés par la CI)
# Les lignes ci-dessous seront ajoutées automatiquement par le workflow CI
# JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
# JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# JWT_PASSPHRASE=testpassphrase