# ===========================================
# SYMFONY / FRAMEWORK
# ===========================================
APP_ENV=dev
APP_DEBUG=true
APP_SECRET=your-app-secret-change-in-production
DEFAULT_URI=http://localhost

# ===========================================
# DATABASE (MySQL)
# ===========================================
# Docker Compose: utilise le service "mysql" au lieu de 127.0.0.1
DATABASE_URL="mysql://onlyroll_db:onlyroll_docker_pass@mysql:3306/onlyroll_db?serverVersion=9.0&charset=utf8mb4"

# Credentials pour l'initialisation MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=onlyroll_db
MYSQL_PASSWORD=onlyroll_docker_pass
MYSQL_DATABASE=onlyroll_db

# ===========================================
# JWT (Lexik Authentication)
# ===========================================
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE="onlyroll123!"

# ===========================================
# CORS (Nelmio CORS Bundle)
# ===========================================
CORS_ALLOW_ORIGIN=http://localhost:5173

# ===========================================
# MERCURE (WebSocket - Symfony Bundle)
# ===========================================
# URL interne (utilisée par le backend pour publier)
MERCURE_URL=http://mercure:3000/.well-known/mercure
# URL publique (utilisée par le frontend pour s'abonner)
MERCURE_PUBLIC_URL=http://localhost:3000/.well-known/mercure
# Secret JWT pour Mercure (doit correspondre au Caddyfile)
MERCURE_JWT_SECRET="uhMPKzA2Ta034+z/ktuKM0w6LZTrj1R1tgPBJ4Emwtg="

# ===========================================
# REDIS (Cache et Sessions)
# ===========================================
# Docker Compose: utilise le service "redis" au lieu de localhost
REDIS_URL=redis://redis:6379

# ===========================================
# FRONTEND (Vue.js + Vite)
# ===========================================
# URL de l'API depuis le conteneur frontend
# http://localhost/api = accès via nginx (reverse proxy)
VITE_API_URL=http://localhost/api

# URL de Mercure pour WebSockets
VITE_MERCURE_URL=http://localhost:3000/.well-known/mercure

# Infos de l'application
VITE_APP_NAME=OnlyRoll
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# URLs supplémentaires
VITE_TERMS_URL=/terms
VITE_PRIVACY_URL=/privacy
VITE_SUPPORT_EMAIL=support@onlyroll.com

# ===========================================
# DOCKER COMPOSE
# ===========================================
# Ports exposés
NGINX_PORT=80
FRONTEND_PORT=5173
MERCURE_PORT=3000
DB_PORT=3306
REDIS_PORT=6379

# Identifiant du projet Docker
COMPOSE_PROJECT_NAME=onlyroll

# ===========================================
# NOTES POUR DÉVELOPPEMENT
# ===========================================
# - Les services sont nommés (mysql, redis, mercure, etc.)
#   et communiquent via le réseau Docker "onlyroll-network"
# - Les URLs internes utilisent les noms de service (ex: mysql:3306)
# - Les URLs publiques utilisent localhost (ex: localhost/api)
# - Le reverse proxy Nginx sur le port 80 route :
#   * /api/* -> php-fpm:9000 (backend)
#   * http://localhost:5173 -> node_dev (frontend Vite)
#   * http://localhost:3000 -> mercure (WebSocket)
